{
  "manifest_version": 3,
  "name": "Ultimate Bookmarks Manager Extension",
  "description": "",
  "author": "Kelish Rai",
  "version": "25.10.11",
  "permissions": ["bookmarks", "notifications"],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/services.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ]
}
